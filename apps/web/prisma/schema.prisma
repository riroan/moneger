// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  transactions   Transaction[]
  categories     Category[]
  budgets        Budget[]
  dailyBalances  DailyBalance[]
  savingsGoals       SavingsGoal[]
  transactionGroups  TransactionGroup[]
  recurringExpenses  RecurringExpense[]
}

model Category {
  id            String    @id @default(cuid())
  name          String
  type          TransactionType
  color         String?
  icon          String?
  defaultBudget Float?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  transactions      Transaction[]
  budgets           Budget[]
  recurringExpenses RecurringExpense[]

  @@unique([userId, name, type])
  @@index([userId, deletedAt])
}

model Transaction {
  id            String          @id @default(cuid())
  amount        Float
  type          TransactionType
  description   String?
  date          DateTime        @default(now())
  categoryId    String?
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  savingsGoalId String?
  savingsGoal   SavingsGoal?    @relation(fields: [savingsGoalId], references: [id], onDelete: SetNull)
  groupId            String?
  group              TransactionGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  recurringExpenseId String?
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([userId, type])
  @@index([userId, deletedAt, date])
  @@index([userId, date, type])
  @@index([savingsGoalId])
  @@index([groupId])
  @@index([recurringExpenseId])
}

model Budget {
  id         String    @id @default(cuid())
  amount     Float
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  month      DateTime
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}

model DailyBalance {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  balance   Float
  income    Float
  expense   Float
  savings   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  name          String
  icon          String
  targetAmount  Float
  currentAmount Float     @default(0)
  startYear     Int?
  startMonth    Int?
  targetYear    Int
  targetMonth   Int
  isPrimary     Boolean   @default(false)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  transactions Transaction[]

  @@index([userId, deletedAt])
}

model TransactionGroup {
  id          String    @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId, deletedAt])
  @@index([userId, createdAt])
}

model RecurringExpense {
  id          String          @id @default(cuid())
  userId      String
  amount      Float
  description String
  type        TransactionType @default(EXPENSE)
  categoryId  String?
  dayOfMonth  Int
  nextDueDate DateTime        @db.Date
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  history      RecurringExpenseHistory[]

  @@index([userId, isActive])
  @@index([nextDueDate])
}

model RecurringExpenseHistory {
  id                 String   @id @default(cuid())
  recurringExpenseId String
  previousAmount     Float
  newAmount          Float
  changedAt          DateTime @default(now())

  recurringExpense RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)

  @@index([recurringExpenseId])
}

enum TransactionType {
  INCOME
  EXPENSE
}
