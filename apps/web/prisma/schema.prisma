// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  password             String
  defaultExpenseBudget Float?
  // 요금제 구분(결제 본체는 아직 없음). FREE 기본, PRO는 DB에서 직접 부여.
  // planExpiresAt가 지나면 entitlements에서 FREE로 취급(만료). 결제 도입 시 이 필드만 세팅하면 됨.
  plan                 Plan      @default(FREE)
  planSince            DateTime?
  planExpiresAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  transactions          Transaction[]
  categories            Category[]
  budgets               Budget[]
  dailyBalances         DailyBalance[]
  savingsGoals          SavingsGoal[]
  transactionGroups     TransactionGroup[]
  recurringExpenses     RecurringExpense[]
  assetItems            AssetItem[]
  assetSnapshots        AssetSnapshot[]
  monthlyAssetSnapshots MonthlyAssetSnapshot[]
  assetAiSummaries      AssetAiSummary[]
  brokerageConnections  BrokerageConnection[]
  sessions              Session[]
}

// 서버 세션. 원본 토큰은 저장하지 않고 SHA-256 해시만 저장(DB 유출 시에도 세션 재현 불가).
model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  userAgent String?   @db.Text
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id            String          @id @default(cuid())
  name          String
  type          TransactionType
  color         String?
  icon          String?
  defaultBudget Float?
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  transactions      Transaction[]
  budgets           Budget[]
  recurringExpenses RecurringExpense[]

  @@unique([userId, name, type])
  @@index([userId, deletedAt])
}

model Transaction {
  id                 String            @id @default(cuid())
  amount             Float
  type               TransactionType
  description        String?
  date               DateTime          @default(now())
  categoryId         String?
  category           Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  savingsGoalId      String?
  savingsGoal        SavingsGoal?      @relation(fields: [savingsGoalId], references: [id], onDelete: SetNull)
  groupId            String?
  group              TransactionGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  recurringExpenseId String?
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  @@index([userId, type])
  @@index([userId, deletedAt, date])
  @@index([userId, date, type])
  @@index([savingsGoalId])
  @@index([groupId])
  @@index([recurringExpenseId])
}

model Budget {
  id         String    @id @default(cuid())
  amount     Float
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  month      DateTime
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([userId, categoryId, month])
  @@index([userId, month])
}

model DailyBalance {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  balance   Float
  income    Float
  expense   Float
  savings   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  name          String
  icon          String
  targetAmount  Float
  currentAmount Float     @default(0)
  startYear     Int?
  startMonth    Int?
  targetYear    Int
  targetMonth   Int
  isPrimary     Boolean   @default(false)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  transactions      Transaction[]
  brokerageAccounts BrokerageAccount[]

  @@index([userId, deletedAt])
}

model TransactionGroup {
  id          String    @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId, deletedAt])
  @@index([userId, createdAt])
}

model RecurringExpense {
  id          String          @id @default(cuid())
  userId      String
  amount      Float
  description String
  type        TransactionType @default(EXPENSE)
  categoryId  String?
  dayOfMonth  Int
  nextDueDate DateTime        @db.Date
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  history      RecurringExpenseHistory[]

  @@index([userId, isActive])
  @@index([nextDueDate])
}

model RecurringExpenseHistory {
  id                 String   @id @default(cuid())
  recurringExpenseId String
  previousAmount     Float
  newAmount          Float
  changedAt          DateTime @default(now())

  recurringExpense RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)

  @@index([recurringExpenseId])
}

model AssetItem {
  id        String    @id @default(cuid())
  userId    String
  name      String
  icon      String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots AssetSnapshot[]

  @@unique([userId, name, deletedAt])
  @@index([userId, deletedAt])
}

model AssetSnapshot {
  id          String   @id @default(cuid())
  userId      String
  assetItemId String
  month       DateTime @db.Date
  amount      Float
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetItem AssetItem @relation(fields: [assetItemId], references: [id], onDelete: Cascade)

  @@unique([assetItemId, month])
  @@index([userId, month])
}

model MonthlyAssetSnapshot {
  id                  String   @id @default(cuid())
  userId              String
  month               DateTime @db.Date
  totalAssetKrw       Float
  cashKrw             Float
  investmentKrw       Float
  savingsKrw          Float
  otherKrw            Float    @default(0)
  cashRatio           Float
  investmentRatio     Float
  savingsRatio        Float
  otherRatio          Float    @default(0)
  monthlyIncomeKrw    Float
  monthlyExpenseKrw   Float
  monthlySavingsKrw   Float
  investmentPnlKrw    Float
  investmentChangeKrw Float?
  sourceStatus        String   @default("computed")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

model AssetAiSummary {
  id          String   @id @default(cuid())
  userId      String
  month       DateTime @db.Date
  text        String   @db.Text
  source      String
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

enum TransactionType {
  INCOME
  EXPENSE
}

// 요금제. 결제 도입 시 티어만 추가하면 entitlements 게이트는 불변.
// ULTIMATE는 개인(관리자) 최상위 등급으로 모든 기능을 가지며 만료되지 않는다.
enum Plan {
  FREE
  PRO
  ULTIMATE
}

enum Broker {
  KIS
  TOSS
}

enum ConnectionStatus {
  ACTIVE
  ERROR
  DISABLED
}

// 증권사 연결. 자격증명은 AES-256-GCM으로 암호화 저장(평문 미저장).
// 복호화는 서버에서 호출 시점에만, AAD = userId+connectionId로 바인딩.
model BrokerageConnection {
  id            String           @id @default(cuid())
  userId        String
  broker        Broker
  label         String?
  ciphertext    Bytes // 암호화된 자격증명 JSON
  iv            Bytes
  authTag       Bytes
  keyVersion    Int              @default(1) // 마스터 키 회전 대비 (회전 자동화는 TODOS.md)
  status        ConnectionStatus @default(ACTIVE)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  failureReason String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts BrokerageAccount[]

  @@unique([userId, broker, label])
  @@index([userId, deletedAt])
  @@index([status])
}

model BrokerageAccount {
  id                String   @id @default(cuid())
  connectionId      String
  externalAccountId String
  displayName       String
  accountType       String // domestic | overseas | isa | unknown
  baseCurrency      String // KRW 등
  // 저축 목표 연결(1목표 ↔ N계좌). 계좌는 최대 1목표에 속한다.
  // 연결되면 총자산 savingsKrw에서 그 목표의 원금을 제외(투자 평가액이 대신 카운트)해
  // 이중계상을 막는다. 목표 삭제 시 SetNull → 계좌는 다시 미연결.
  savingsGoalId     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  connection  BrokerageConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  savingsGoal SavingsGoal?        @relation(fields: [savingsGoalId], references: [id], onDelete: SetNull)
  snapshots   BrokerageSnapshot[]

  @@unique([connectionId, externalAccountId])
  @@index([connectionId])
  @@index([savingsGoalId])
}

// 일별 스냅샷. 멱등 키 = (accountId, date). 금액은 KRW 정규화 + Decimal.
model BrokerageSnapshot {
  id                String   @id @default(cuid())
  accountId         String
  date              DateTime @db.Date
  cashKrw           Decimal  @db.Decimal(20, 2)
  cashBalances      Json?
  totalEquityKrw    Decimal  @db.Decimal(20, 2)
  positionsValueKrw Decimal  @db.Decimal(20, 2)
  asOf              DateTime // 증권사 평가 기준시각
  createdAt         DateTime @default(now())

  account   BrokerageAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  positions BrokeragePosition[]

  @@unique([accountId, date])
  @@index([accountId, date])
}

model BrokeragePosition {
  id             String   @id @default(cuid())
  snapshotId     String
  symbol         String
  name           String
  market         String? // KRX, NASDAQ ...
  currency       String // KRW, USD ...
  quantity       Decimal  @db.Decimal(28, 8)
  avgCost        Decimal? @db.Decimal(20, 4)
  lastPrice      Decimal? @db.Decimal(20, 4)
  marketValue    Decimal  @db.Decimal(20, 4) // 원통화 평가액
  marketValueKrw Decimal  @db.Decimal(20, 2) // 환산 평가액
  unrealizedPnl  Decimal? @db.Decimal(20, 4)
  fxRateToKrw    Decimal? @db.Decimal(18, 6)

  snapshot BrokerageSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
}
